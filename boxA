bool connectWiFi() {
  String ssid, pass;
  if (!loadWiFi(ssid, pass)) {
    Serial.println("No saved WiFi. Box A will start Setup-boxA AP for setup.");
    return false;
  }

  ssid.trim();
  Serial.println("========== WiFi Connect boxA ==========");
  Serial.print("Target SSID: ");
  Serial.println(ssid);

  // Important fix:
  // When Setup-boxA AP is running on ESP-NOW channel 7, connecting to a router on another
  // channel can fail in AP+STA mode. Stop SoftAP first, connect as STA only, then restart
  // AP only if connection fails. This avoids the repeated status=6 failure seen in Serial.
  if (apRunning) {
    Serial.println("Temporarily stop Setup-boxA AP before router WiFi connect.");
    WiFi.softAPdisconnect(true);
    apRunning = false;
    delay(500);
  }

  if (espNowReady) {
    Serial.println("Temporarily stop ESP-NOW before router WiFi connect.");
    esp_now_deinit();
    espNowReady = false;
    delay(100);
  }

  WiFi.persistent(false);
  WiFi.mode(WIFI_STA);
  WiFi.setSleep(false);
  esp_wifi_set_protocol(WIFI_IF_STA, WIFI_PROTOCOL_11B | WIFI_PROTOCOL_11G | WIFI_PROTOCOL_11N);
  esp_wifi_set_ps(WIFI_PS_NONE);
  WiFi.setHostname(HOSTNAME);
  WiFi.disconnect(false, false);  // keep saved credentials in Preferences; only disconnect radio session
  delay(600);

  Serial.print("Scanning WiFi before connect: ");
  Serial.println(ssid);

  int n = WiFi.scanNetworks(false, true);
  int bestIndex = -1;
  int bestRSSI = -999;
  int bestChannel = 0;
  bool bestIsPreferredChannel = false;  // v16: stays false when PREFERRED_ROUTER_CHANNEL=0
  uint8_t bestBSSID[6] = {0};

  Serial.print("Found networks: ");
  Serial.println(n);
  for (int i = 0; i < n; i++) {
    Serial.print(i);
    Serial.print(": SSID: ");
    Serial.print(WiFi.SSID(i));
    Serial.print(" | RSSI: ");
    Serial.print(WiFi.RSSI(i));
    Serial.print(" | CH: ");
    Serial.print(WiFi.channel(i));
    Serial.print(" | BSSID: ");
    Serial.println(WiFi.BSSIDstr(i));

    if (WiFi.SSID(i) == ssid && WiFi.RSSI(i) > bestRSSI) {
      // v16: Do not force CH7/CH11 here. Connect to the strongest matching SSID.
      // ESP-NOW will use the router's actual channel after connection, and Box B will search for it while offline.
      bestIndex = i;
      bestRSSI = WiFi.RSSI(i);
      bestChannel = WiFi.channel(i);
      bestIsPreferredChannel = false;
      memcpy(bestBSSID, WiFi.BSSID(i), 6);
    }
  }

  if (bestIndex < 0) {
    Serial.println("Target WiFi not found. Box A will start/keep Setup-boxA AP for setup.");
    WiFi.scanDelete();
    return false;
  }

  Serial.print("Best AP channel=");
  Serial.print(bestChannel);
  Serial.print(" RSSI=");
  Serial.print(bestRSSI);
  Serial.print(" BSSID=");
  Serial.println(WiFi.BSSIDstr(bestIndex));

  Serial.println("WiFi attempt 1: connect with fixed channel+BSSID");
  WiFi.begin(ssid.c_str(), pass.c_str(), bestChannel, bestBSSID, true);

  unsigned long start = millis();
  while (WiFi.status() != WL_CONNECTED && millis() - start < WIFI_CONNECT_ATTEMPT1_TIMEOUT_MS) {
    delay(500);
    Serial.print(".");
  }
  Serial.println();

  if (WiFi.status() != WL_CONNECTED) {
    Serial.print("Attempt 1 failed status=");
    Serial.println(WiFi.status());
    Serial.println("WiFi attempt 2: connect by SSID only, let ESP32 choose BSSID/channel");

    WiFi.disconnect(false, false);
    delay(800);
    WiFi.begin(ssid.c_str(), pass.c_str());

    start = millis();
    while (WiFi.status() != WL_CONNECTED && millis() - start < WIFI_CONNECT_ATTEMPT2_TIMEOUT_MS) {
      delay(500);
      Serial.print(".");
    }
    Serial.println();
  }

  int finalStatus = WiFi.status();
  WiFi.scanDelete();

  if (finalStatus == WL_CONNECTED) {
    Serial.println("WiFi connected SUCCESS");
    Serial.print("IP: ");
    Serial.println(WiFi.localIP());
    Serial.print("RSSI: ");
    Serial.println(WiFi.RSSI());
    Serial.print("Channel: ");
    Serial.println(WiFi.channel());
    Serial.print("MAC: ");
    Serial.println(WiFi.macAddress());
    return true;
  }

  Serial.print("WiFi connected FAILED status=");
  Serial.println(finalStatus);
  Serial.println("Most common causes: wrong password, router rejects ESP32, or 2.4 GHz security/channel setting issue.");
  return false;
}

void startAPMode() {
  // Box A local AP.
  // If STA is connected, SoftAP must use the same channel as the router.
  // If STA is not connected, use the same fixed channel as Box B ESP-NOW.
  WiFi.persistent(false);
  WiFi.mode(WIFI_AP_STA);
  WiFi.setSleep(false);
  esp_wifi_set_protocol(WIFI_IF_STA, WIFI_PROTOCOL_11B | WIFI_PROTOCOL_11G | WIFI_PROTOCOL_11N);
  esp_wifi_set_protocol(WIFI_IF_AP, WIFI_PROTOCOL_11B | WIFI_PROTOCOL_11G | WIFI_PROTOCOL_11N);
  esp_wifi_set_ps(WIFI_PS_NONE);
  WiFi.setHostname(HOSTNAME);
  esp_wifi_set_max_tx_power(78); // 19.5 dBm, stronger local AP signal.
  delay(150);

  int apChannel = ESPNOW_WIFI_CHANNEL;
  if (WiFi.status() == WL_CONNECTED && WiFi.channel() > 0) {
    apChannel = WiFi.channel();
  }

  // Restart SoftAP every time this is requested. This avoids the AP staying on an old
  // channel after WiFi reconnects or after ESP-NOW changes channel.
  WiFi.softAPdisconnect(true);
  delay(300);
  WiFi.softAPConfig(IPAddress(192, 168, 4, 1), IPAddress(192, 168, 4, 1), IPAddress(255, 255, 255, 0));

  bool ok = false;
  for (int attempt = 1; attempt <= 3 && !ok; attempt++) {
    ok = WiFi.softAP(AP_SSID, AP_PASS, apChannel, 0, 8);
    delay(400);
    Serial.print("AP attempt ");
    Serial.print(attempt);
    Serial.print(" result: ");
    Serial.println(ok ? "OK" : "FAILED");
  }

  // Keep radio on the AP/ESP-NOW channel when Box A is offline.
  // This makes Setup-boxA visible and keeps Box B reachable.
  if (WiFi.status() != WL_CONNECTED) {
    esp_wifi_set_channel(apChannel, WIFI_SECOND_CHAN_NONE);
  }

  apRunning = ok;
  if (ok) {
    apStartMillis = millis();
    holdAPConfigWindow("ap_start");
  }

  Serial.println("========== Local AP Start boxA ==========");
  Serial.print("AP result: ");
  Serial.println(ok ? "OK" : "FAILED");
  Serial.print("AP SSID: ");
  Serial.println(AP_SSID);
  Serial.print("AP PASS: ");
  Serial.println(AP_PASS);
  Serial.print("AP channel: ");
  Serial.println(apChannel);
  Serial.print("AP IP: ");
  Serial.println(WiFi.softAPIP());
  Serial.print("AP MAC: ");
  Serial.println(WiFi.softAPmacAddress());
  Serial.println("Open http://192.168.4.1 . If WiFi is not connected, AP will stay active for setup.");

  // v15: SoftAP shares the same radio. After AP starts, refresh ESP-NOW peers on the current channel.
  if (espNowReady) {
    lastEspNowPeerChannel = 0;
    lastEspNowPeerIfidx = WIFI_IF_STA;
    ensureEspNowPeer(activeBoxBMac);
    ensureEspNowPeer(ESP_NOW_BROADCAST_MAC);
  }
}

void stopAPMode() {
  if (!apRunning) return;
  WiFi.softAPdisconnect(true);
  apRunning = false;

  if (WiFi.status() == WL_CONNECTED) {
    WiFi.mode(WIFI_STA);
  } else {
    WiFi.mode(WIFI_STA);
  }
  WiFi.setSleep(false);
  esp_wifi_set_ps(WIFI_PS_NONE);
