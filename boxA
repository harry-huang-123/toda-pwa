uint64_t readCommandSeq(JsonVariantConst value) {
  if (value.is<uint64_t>()) return value.as<uint64_t>();
  if (value.is<unsigned long>()) return value.as<unsigned long>();
  if (value.is<long>()) {
    long v = value.as<long>();
    return v > 0 ? (uint64_t)v : 0;
  }
  if (value.is<double>()) {
    double v = value.as<double>();
    return v > 0 ? (uint64_t)v : 0;
  }
  if (value.is<const char *>()) {
    return strtoull(value.as<const char *>(), nullptr, 10);
  }
  return 0;
}

