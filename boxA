void readFastCommand() {
  // Ultra-fast manual command channel.
  // Read only /commands/boxA and /commands/boxB here.
  // Do not read the whole /commands tree or /boxes every 150 ms,
  // otherwise HTTPS GET becomes slow and GPIO4 reaction feels delayed.

  String payloadA;
  if (firebaseGetRaw("/commands/boxA", payloadA)) {
    DynamicJsonDocument docA(2048);
    DeserializationError errA = deserializeJson(docA, payloadA);

    if (!errA) {
      uint64_t seq = readCommandSeq(docA["commandSeq"]);

      if (seq != 0 && seq != lastCommandSeqSeen) {
        lastCommandSeqSeen = seq;

        bool mMode = docA["manualMode"] | false;
        bool mValve = docA["manualValve"] | false;
        bool resumeAuto = docA["resumeAuto"] | false;
        bool clearFault = docA["clearFault"] | false;
        bool clearTodayCmd = docA["clearTodayStatus"] | false;
        bool requestLocalAPCmd = docA["requestLocalAP"] | false;
        String commandSource = docA["commandSource"] | "";

        Serial.print("FAST COMMAND A from=/commands/boxA seq=");
        Serial.print(u64ToString(seq));
        Serial.print(" manualMode="); Serial.print(mMode);
        Serial.print(" manualValve="); Serial.print(mValve);
        Serial.print(" resumeAuto="); Serial.println(resumeAuto);
        refreshBoxASettingsOnce("fast_command_A");
        if (resumeAuto || mMode) lastManualCommandMillisA = millis();

        if (requestLocalAPCmd && commandSource == "web_local_ap") {
          startAPMode();
          lastCommandSeqAckA = seq;
          firebasePutBool("/commands/boxA/requestLocalAP", false);
          firebasePutBool(ownPath("/requestLocalAP"), false);
          firebasePutBool(ownPath("/localAPActive"), apRunning);
          firebasePutString(ownPath("/localAPSSID"), AP_SSID);
          firebasePutString(ownPath("/localAPIP"), WiFi.softAPIP().toString());
          statusDirty = true;
          uploadStatus();
        } else if (clearTodayCmd && commandSource == "web_clear_today") {
          clearTodayState();
          firebasePutBool("/commands/boxA/clearTodayStatus", false);
          lastCommandSeqAckA = seq;
          statusDirty = true;
          uploadStatus();
        } else {
          if (clearTodayCmd && commandSource != "web_clear_today") {
            firebasePutBool("/commands/boxA/clearTodayStatus", false);
          }

          if (clearFault || mMode) {
            valveFault = false;
            faultReason = "";
            waterDetected = false;
            wateringConfirmed = false;
          }

          if (resumeAuto) {
            manualMode = false;
            manualValve = false;
            autoMode = true;
            currentWateringFromScheduleA = false;
            currentScheduleKeyA = "";
            forceValveImmediate(false, "fast_resume_auto");
            updateLastValveAction("fast_resume_auto", "resume auto");
          } else if (mMode && mValve) {
            manualMode = true;
            manualValve = true;
            autoMode = false;
            valveFault = false;
            faultReason = "";
            waterDetected = false;
            wateringConfirmed = false;
            forceValveImmediate(true, "manual_fast_on");
            updateLastValveAction("manual_fast_on", "manual command on");
          } else if (mMode && !mValve) {
            if (currentWateringFromScheduleA) {
              markCurrentScheduleHandledA("schedule_manual_stop_recorded");
            } else if (matchedScheduleSlotA().length() > 0) {
              markCurrentScheduleWindowHandledA("manual_off_inside_schedule_window");
            }
            waterDetected = false;
            wateringConfirmed = false;
            currentWateringFromScheduleA = false;
            currentScheduleKeyA = "";
            forceValveImmediate(false, "manual_fast_off");
            manualMode = false;
            manualValve = false;
            autoMode = true;
            updateLastValveAction("manual_fast_off", "manual command off");
          }
          lastCommandSeqAckA = seq;
          statusDirty = true;
          uploadStatus();
        }
      }
    } else {
      Serial.print("FAST COMMAND A parse failed: ");
      Serial.println(errA.c_str());
    }
  }

  String payloadB;
  if (firebaseGetRaw("/commands/boxB", payloadB)) {
    DynamicJsonDocument docB(2048);
    DeserializationError errB = deserializeJson(docB, payloadB);

    if (!errB) {
      uint64_t seqB = readCommandSeq(docB["commandSeq"]);

      if (seqB != 0 && seqB != lastCommandSeqSeenB) {
        lastCommandSeqSeenB = seqB;
        lastCommandSeqAckB = seqB;

        bool resumeAutoB = docB["resumeAuto"] | false;
        bool clearTodayB = (docB["clearTodayStatus"] | false) || (docB["clearFault"] | false);
        bool requestLocalAPB = docB["requestLocalAP"] | false;
        bool hasManualFieldB = docB["manualMode"].is<bool>() || docB["manualValve"].is<bool>();
        bool isActionCommandB = hasManualFieldB || resumeAutoB || clearTodayB || requestLocalAPB;

        refreshBoxBSettingsOnce("fast_command_B");

        // Settings-only pings, such as scheduleSavePing/settingsPing, must not become a valve action.
        // They only refresh runtime settings and send a neutral heartbeat to Box B.
        if (!isActionCommandB) {
          Serial.print("FAST COMMAND B settings-only from=/commands/boxB seq=");
          Serial.println(u64ToString(seqB));
          cmdB.requestId = 0;
          cmdB.startWaterRequest = false;
          cmdB.clearTodayStatus = false;
          cmdB.requestLocalAP = false;
          cmdB.offlineScheduleBypass = offlineScheduleBypassBByGateway();
          sendCommandToB();
          uploadStatus();
          return;
        }

        cmdB.manualMode = resumeAutoB ? false : (docB["manualMode"] | false);
        cmdB.manualValve = resumeAutoB ? false : (docB["manualValve"] | false);
        cmdB.autoMode = resumeAutoB ? true : !cmdB.manualMode;
        cmdB.requestId = (uint32_t)(seqB & 0xFFFFFFFFULL);
        if (cmdB.requestId == 0) cmdB.requestId = 1;
        cmdB.startWaterRequest = false;
        cmdB.clearTodayStatus = clearTodayB;
        cmdB.requestLocalAP = requestLocalAPB;

        // Manual control clears old no-water fault and is sent immediately.
        if (cmdB.manualMode) {
          cmdB.clearTodayStatus = true;
          if (!cmdB.manualValve && matchedScheduleSlotBByGateway().length() > 0) {
            markCurrentScheduleWindowHandledBByGateway("manual_off_inside_schedule_window");
          }
        }

        Serial.print("FAST COMMAND B action from=/commands/boxB seq=");
        Serial.print(u64ToString(seqB));
        Serial.print(" manualMode=");
        Serial.print(cmdB.manualMode);
        Serial.print(" manualValve=");
        Serial.print(cmdB.manualValve);
        Serial.print(" resumeAuto=");
        Serial.print(resumeAutoB);
        Serial.print(" clear=");
        Serial.print(cmdB.clearTodayStatus);
        Serial.print(" requestAP=");
        Serial.println(cmdB.requestLocalAP);

        // v23: optimistic local state first. This prevents uploadStatus() from writing
        // the old Box B valve state back to Firebase while waiting for B's return status.
        if (cmdB.manualMode) {
          boxBValve = cmdB.manualValve;
          boxBValveFault = false;
          boxBWaterDetected = false;
          boxBWateringConfirmed = false;
          if (!cmdB.manualValve) {
            boxBRemain = 0;
            boxBScheduleRemainSeconds = 0;
            boxBNoWaterTimeoutRemainSeconds = 0;
          }
        }

        // v23: short but dense burst. OFF must feel as fast as ON.
        // Keep this before any uploadStatus()/Firebase write.
        for (int i = 0; i < 80; i++) {
          sendCommandToB();
          delay(5);
        }

        clearBoxBOneShotCommand("fast_command_B_sent");
        sendCommandToB();
        uploadStatus();
      }
    } else {
      Serial.print("FAST COMMAND B parse failed: ");
      Serial.println(errB.c_str());
    }
  }

}


void primeCommandSeqsFromFirebase(const char *reason) {
  // v13 fix:
  // On reboot, /commands/boxA and /commands/boxB may still contain the last commandSeq.
  // If lastCommandSeqSeen starts from 0, the gateway replays that old ON/OFF command once.
  // Prime the sequence numbers at boot/reconnect so only NEW web commands take action.
  if (WiFi.status() != WL_CONNECTED) return;

  String payloadA;
  if (firebaseGetRaw("/commands/boxA", payloadA)) {
    DynamicJsonDocument docA(2048);
    DeserializationError errA = deserializeJson(docA, payloadA);
    if (!errA) {
      uint64_t seqA = readCommandSeq(docA["commandSeq"]);
      if (seqA != 0) {
        lastCommandSeqSeen = seqA;
        lastCommandSeqAckA = seqA;
        Serial.print("Prime commandSeq A reason=");
        Serial.print(reason ? reason : "");
        Serial.print(" seq=");
        Serial.println(u64ToString(seqA));
      }
    }
  }

  String payloadB;
  if (firebaseGetRaw("/commands/boxB", payloadB)) {
    DynamicJsonDocument docB(2048);
    DeserializationError errB = deserializeJson(docB, payloadB);
    if (!errB) {
      uint64_t seqB = readCommandSeq(docB["commandSeq"]);
      if (seqB != 0) {
        lastCommandSeqSeenB = seqB;
        lastCommandSeqAckB = seqB;
        Serial.print("Prime commandSeq B reason=");
        Serial.print(reason ? reason : "");
        Serial.print(" seq=");
        Serial.println(u64ToString(seqB));
      }
    }
  }
}

void readFirebaseSettings() {
  String payloadA;
  if (firebaseGetRaw(basePath(), payloadA)) {
    DynamicJsonDocument docA(12288);
    DeserializationError errA = deserializeJson(docA, payloadA);
    if (!errA) {
      bool allowFirebaseManualState = (millis() - lastManualCommandMillisA > 2000UL);
      if (allowFirebaseManualState) {
        firebaseGetBoolFromJson(docA, "manualMode", manualMode);
        firebaseGetBoolFromJson(docA, "manualValve", manualValve);
        firebaseGetBoolFromJson(docA, "autoMode", autoMode);
      }
      bool oldScheduleEnabledA = scheduleEnabled;
      firebaseGetBoolFromJson(docA, "scheduleEnabled", scheduleEnabled);
      firebaseGetBoolFromJson(docA, "offlineScheduleContinue", offlineScheduleContinue);

      int tempInt = wateringSeconds;
      if (firebaseGetIntFromJson(docA, "wateringSeconds", tempInt)) wateringSeconds = validWateringSeconds(tempInt);
      tempInt = noWaterTimeoutSeconds;
      if (firebaseGetIntFromJson(docA, "noWaterTimeoutSeconds", tempInt)) noWaterTimeoutSeconds = validWateringSeconds(tempInt);
      firebaseGetBoolFromJson(docA, "useRainStopRule", useRainStopRule);
      firebaseGetBoolFromJson(docA, "useWeatherRule", useWeatherRule);
      String oldSchedule1 = schedule1;
      String oldSchedule2 = schedule2;
      firebaseGetStringFromJson(docA, "schedule1", schedule1);
      firebaseGetStringFromJson(docA, "schedule2", schedule2);
      if (schedule1 != oldSchedule1 || schedule2 != oldSchedule2) {
        if (currentWateringFromScheduleA) {
          Serial.println("Schedule A time changed while watering. Stop old schedule run immediately.");
          markCurrentScheduleHandledA("schedule_changed_stop_recorded");
          currentWateringFromScheduleA = false;
          currentScheduleKeyA = "";
          waterDetected = false;
          wateringConfirmed = false;
          forceValveImmediate(false, "schedule_changed_off");
          updateLastValveAction("schedule_changed_off", "schedule changed");
        }
        lastScheduleStartKeyA = ""; lastScheduleSkipKeyA = ""; manualStoppedScheduleKeyA = ""; lastNoWaterFaultKeyA = ""; lastScheduleAttemptMillis = 0;
        Serial.print("Schedule A updated: ");
        Serial.print(schedule1);
        Serial.print(" / ");
        Serial.println(schedule2);
      }

      if (!oldScheduleEnabledA && scheduleEnabled) markCurrentScheduleWindowHandledA("schedule_enabled_late_no_catchup");

      bool clearA = false;
      if (firebaseGetBoolFromJson(docA, "clearTodayStatus", clearA) && clearA) clearTodayState();

      bool requestLocalAPA = false;
      if (firebaseGetBoolFromJson(docA, "requestLocalAP", requestLocalAPA) && requestLocalAPA) {
        startAPMode();
        firebasePutBool(ownPath("/requestLocalAP"), false);
        firebasePutString(ownPath("/localAPMessage"), "AP active for 20 minutes");
      }
    }
  }

  String payloadB;
  if (firebaseGetRaw("/boxes/boxB", payloadB)) {
    DynamicJsonDocument docB(12288);
    DeserializationError errB = deserializeJson(docB, payloadB);
    if (!errB) {
      bool oldScheduleEnabledB = cmdB.scheduleEnabled;
      // v12: Do not read boxB manualMode/manualValve/autoMode from /boxes/boxB here.
      // Only /commands/boxB is allowed to change Box B's relay.
      // This prevents A-zone status/settings refresh from sending a stale OFF command to Box B.
      firebaseGetBoolFromJson(docB, "scheduleEnabled", cmdB.scheduleEnabled);
      firebaseGetBoolFromJson(docB, "offlineScheduleContinue", boxBOfflineScheduleContinue);

      int tempInt = cmdB.wateringSeconds;
      if (firebaseGetIntFromJson(docB, "wateringSeconds", tempInt)) cmdB.wateringSeconds = validWateringSeconds(tempInt);
      tempInt = boxBNoWaterTimeoutSeconds;
      if (firebaseGetIntFromJson(docB, "noWaterTimeoutSeconds", tempInt)) boxBNoWaterTimeoutSeconds = validWateringSeconds(tempInt);
      cmdB.noWaterTimeoutSeconds = boxBNoWaterTimeoutSeconds;
      firebaseGetBoolFromJson(docB, "useRainStopRule", boxBUseRainStopRule);
      cmdB.useRainStopRule = boxBUseRainStopRule;
      String oldBoxBSchedule1 = boxBSchedule1;
      String oldBoxBSchedule2 = boxBSchedule2;
      firebaseGetStringFromJson(docB, "schedule1", boxBSchedule1);
      firebaseGetStringFromJson(docB, "schedule2", boxBSchedule2);
      if (boxBSchedule1 != oldBoxBSchedule1 || boxBSchedule2 != oldBoxBSchedule2) {
        lastBoxBScheduleStartKey = ""; lastBoxBScheduleSkipKey = ""; manualStoppedBoxBScheduleKey = ""; lastBoxBScheduleAttemptMillis = 0;
        Serial.print("Schedule B updated: ");
        Serial.print(boxBSchedule1);
        Serial.print(" / ");
        Serial.println(boxBSchedule2);
      }

      if (!oldScheduleEnabledB && cmdB.scheduleEnabled) markCurrentScheduleWindowHandledBByGateway("schedule_enabled_late_no_catchup");

      cmdB.clearTodayStatus = false;
      bool clearB = false;
      if (firebaseGetBoolFromJson(docB, "clearTodayStatus", clearB) && clearB) {
        cmdB.clearTodayStatus = true;
        cmdB.scheduleEnabled = true;
        markCurrentScheduleWindowHandledBByGateway("clear_today_restore_schedule_no_catchup");
        firebasePutBool(boxBPath("/clearTodayStatus"), false);
        firebasePutBool(boxBPath("/scheduleEnabled"), true);
      }

      cmdB.requestLocalAP = false;
      bool requestLocalAPB = false;
      if (firebaseGetBoolFromJson(docB, "requestLocalAP", requestLocalAPB) && requestLocalAPB) {
        cmdB.requestLocalAP = true;
        firebasePutBool(boxBPath("/requestLocalAP"), false);
        firebasePutString(boxBPath("/localAPMessage"), "AP request sent to Box B for 20 minutes");
      }
    }
  }

  cmdB.rain = rainBlockedToday || rainState;
  cmdB.weatherBlocked = weatherBlockedB;
  cmdB.weatherRainProbability = weatherRainProbabilityB;
  cmdB.weatherPrecipitationMM = weatherPrecipitationMMB;
  cmdB.startWaterRequest = false;
  cmdB.wateringSeconds = validWateringSeconds(cmdB.wateringSeconds);
  cmdB.noWaterTimeoutSeconds = validWateringSeconds(boxBNoWaterTimeoutSeconds);
  cmdB.useRainStopRule = boxBUseRainStopRule;

  // B 區排程啟動統一交給 controlLogicBByGateway()，避免 readFirebaseSettings() 裡舊邏輯重複觸發。

  printSettingsSummaryAB("periodic_settings_read");
  saveScheduleSettingsToNVS();
}

String matchedScheduleSlotA() {
  if (scheduleTimeMatchesNow(schedule1)) return "1";
