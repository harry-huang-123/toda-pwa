void handleWiFiScanJson() {
  holdAPConfigWindow("wifi_scan_json");

  int scanStatus = WiFi.scanComplete();
  bool startRequested = server.hasArg("start");
  unsigned long now = millis();

  if (startRequested && scanStatus != -1 && (now - lastAsyncWifiScanStart > WIFI_SCAN_RESTART_GUARD_MS)) {
    WiFi.scanDelete();
    int r = WiFi.scanNetworks(true, true);  // async=true, show_hidden=true
    asyncWifiScanRunning = true;
    lastAsyncWifiScanStart = now;
    Serial.print("Async WiFi scan start result=");
    Serial.println(r);
    server.send(200, "application/json", "{\"running\":true}");
    return;
  }

  scanStatus = WiFi.scanComplete();
  if (scanStatus == -1) {
    server.send(200, "application/json", "{\"running\":true}");
    return;
  }

  if (scanStatus < 0) {
    int r = WiFi.scanNetworks(true, true);
    asyncWifiScanRunning = true;
    lastAsyncWifiScanStart = now;
    Serial.print("Async WiFi scan auto-start result=");
    Serial.println(r);
    server.send(200, "application/json", "{\"running\":true}");
    return;
  }

  String json = "{\"running\":false,\"count\":";
  json.concat(String(scanStatus));
  json.concat(",\"networks\":[");
  for (int i = 0; i < scanStatus; i++) {
    if (i > 0) json.concat(",");
    json.concat("{\"ssid\":\"");
    json.concat(jsonEscape(WiFi.SSID(i)));
    json.concat("\",\"rssi\":");
    json.concat(String(WiFi.RSSI(i)));
    json.concat(",\"ch\":");
    json.concat(String(WiFi.channel(i)));
    json.concat(",\"bssid\":\"");
    json.concat(WiFi.BSSIDstr(i));
    json.concat("\"}");
  }
  json.concat("]}");

  WiFi.scanDelete();
  asyncWifiScanRunning = false;
  server.send(200, "application/json", json);
}

