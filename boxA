  if (cmdB.manualMode && cmdB.manualValve) return false;
  if (offlineScheduleBypassBByGateway()) return true;
  if (boxBValveFault) return false;
  // B 區雨滴/潮濕由排程啟動前即時檢查 boxBSensorWet，不用 rainBlockedToday 永久阻擋。
  if (weatherBlockedB || boxBWeatherBlocked) return false;
  return true;
}

void controlLogicBByGateway() {
  unsigned long now = millis();
  if (now - lastScheduleWatchPrintB >= 10000UL) {
    lastScheduleWatchPrintB = now;
    printScheduleWatchBByGateway();
  }

  if (cmdB.manualMode && cmdB.manualValve) return;

  cmdB.startWaterRequest = false;
  cmdB.weatherBlocked = (weatherBlockedB || boxBWeatherBlocked) && !offlineScheduleBypassBByGateway();
  cmdB.weatherRainProbability = weatherRainProbabilityB;
  cmdB.weatherPrecipitationMM = weatherPrecipitationMMB;
  cmdB.noWaterTimeoutSeconds = validWateringSeconds(boxBNoWaterTimeoutSeconds);
  cmdB.useRainStopRule = boxBUseRainStopRule;

  if (!cmdB.scheduleEnabled) return;

  String bSlot = matchedScheduleSlotBByGateway();
  if (bSlot.length() == 0) return;

  String bKey = makeScheduleKeyBByGateway(bSlot);
  if (bKey == lastBoxBScheduleStartKey || bKey == lastBoxBScheduleSkipKey || bKey == manualStoppedBoxBScheduleKey) {
    return;
  }

  if (boxBValve || millis() - lastBoxBScheduleAttemptMillis < SCHEDULE_RETRY_INTERVAL_MS) return;
  lastBoxBScheduleAttemptMillis = millis();

  if (!offlineScheduleBypassBByGateway() && boxBUseRainStopRule && boxBSensorWet) {
    boxBRainBlockedToday = true;
    lastBoxBScheduleSkipKey = bKey;
    pushEventForBox("boxB", "schedule_skip_sensor_wet_before_start", "B區排程時間到，但雨滴/潮濕感測器在電磁閥尚未開啟前已偵測到濕潤，因此本時段不啟動澆水。" );
    if (notifyRainBlocked) sendNtfy("🌧️ B 區雨滴暫停", "B區排程時間到，但澆水前已偵測到雨滴/潮濕，已停止本次排程澆水。", "umbrella");
    firebasePutBool(boxBPath("/rainBlockedToday"), true);
    firebasePutBool(boxBPath("/rain"), true);
    firebasePutInt(boxBPath("/scheduleRemainSeconds"), 0);
    firebasePutInt(boxBPath("/noWaterTimeoutRemainSeconds"), 0);
    return;
  }

  if (!canScheduleWaterBByGateway()) {
    lastBoxBScheduleSkipKey = bKey;
    pushEventForBox("boxB", "schedule_skip_blocked", "B區排程時間到但條件阻擋，未啟動澆水。請確認天氣、故障或手動狀態。" );
    if (notifyWeatherBlocked || notifyNoWaterFault) sendNtfy("⚠️ B 區排程未啟動", "B區排程時間到但條件阻擋，未啟動澆水。請確認天氣、故障或手動狀態。", "warning");
    return;
  }

  cmdB.startWaterRequest = true;
  cmdB.offlineScheduleBypass = offlineScheduleBypassBByGateway();
  cmdB.requestId = millis();
  if (cmdB.requestId == 0) cmdB.requestId = 1;
  lastBoxBScheduleStartKey = bKey;

  Serial.print("SCHEDULE B START REQUEST now=");
  Serial.print(currentHHMM());
  Serial.print(" s1="); Serial.print(boxBSchedule1);
  Serial.print(" s2="); Serial.print(boxBSchedule2);
  Serial.print(" offlineBypass="); Serial.println(offlineScheduleBypassBByGateway());

  pushEventForBox("boxB", "schedule_start_request", "B區排程澆水啟用請求已透過 ESP-NOW 傳送。" );

  // v23: Schedule start is also a one-shot action. Use a short burst so Box B
  // can catch it even while it is recovering/reconnecting, then clear the action bits.
  boxBValve = true;
  boxBRemain = cmdB.wateringSeconds;
  boxBScheduleRemainSeconds = cmdB.wateringSeconds;
  boxBValveFault = false;
  for (int i = 0; i < 80; i++) {
    sendCommandToB();
    delay(5);
  }
  cmdB.startWaterRequest = false;
  cmdB.offlineScheduleBypass = false;
  cmdB.requestId = 0;
  sendCommandToB();
}


void uploadStatus() {
  heartbeatSeq++;

  StaticJsonDocument<2048> a;
  a["singleSensorMode"] = true;
  a["sensorWet"] = sensorWet;
  a["rain"] = rainState || rainBlockedToday;
  a["waterDetected"] = waterDetected;
  a["wateringConfirmed"] = wateringConfirmed;
  a["valveFault"] = valveFault;
  a["faultReason"] = faultReason;
  a["rainBlockedToday"] = rainBlockedToday;
  a["wateredToday"] = wateredToday;
  a["valve"] = valveState;
  a["ip"] = WiFi.localIP().toString();
  a["lastUpdate"] = nowString();
  {
    JsonObject ts = a.createNestedObject("lastUpdateMs");
    ts[".sv"] = "timestamp";
  }
  a["online"] = true;
  a["rssi"] = WiFi.RSSI();
  a["remain"] = remainSeconds();
  a["scheduleRemainSeconds"] = scheduleRemainSecondsA();
  a["noWaterTimeoutRemainSeconds"] = noWaterTimeoutRemainSecondsA();
  a["manualMode"] = manualMode;
  a["manualValve"] = manualValve;
  a["desiredValve"] = valveState;
  a["heartbeatSeq"] = (int)heartbeatSeq;
  a["heartbeatIntervalSec"] = (int)(HEARTBEAT_INTERVAL_MS / 1000);
  a["weatherBlocked"] = weatherBlockedA;
  a["offlineScheduleContinue"] = offlineScheduleContinue;
