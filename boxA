void refreshBoxASettingsOnce(const char *reason) {
  if (WiFi.status() != WL_CONNECTED) return;

  String payload;
  if (!firebaseGetRaw(basePath(), payload)) return;

  DynamicJsonDocument doc(12288);
  DeserializationError err = deserializeJson(doc, payload);
  if (err) {
    Serial.print("A settings refresh parse failed: ");
    Serial.println(err.c_str());
    return;
  }

  bool oldScheduleEnabled = scheduleEnabled;
  String oldSchedule1 = schedule1;
  String oldSchedule2 = schedule2;
  int oldWateringSeconds = wateringSeconds;
  int oldNoWaterTimeoutSeconds = noWaterTimeoutSeconds;

  firebaseGetBoolFromJson(doc, "scheduleEnabled", scheduleEnabled);
  firebaseGetBoolFromJson(doc, "offlineScheduleContinue", offlineScheduleContinue);
  firebaseGetBoolFromJson(doc, "useRainStopRule", useRainStopRule);
  firebaseGetBoolFromJson(doc, "useWeatherRule", useWeatherRule);

  int tempInt = wateringSeconds;
  if (firebaseGetIntFromJson(doc, "wateringSeconds", tempInt)) wateringSeconds = validWateringSeconds(tempInt);
  tempInt = noWaterTimeoutSeconds;
  if (firebaseGetIntFromJson(doc, "noWaterTimeoutSeconds", tempInt)) noWaterTimeoutSeconds = validWateringSeconds(tempInt);

  firebaseGetStringFromJson(doc, "schedule1", schedule1);
  firebaseGetStringFromJson(doc, "schedule2", schedule2);

  if (oldSchedule1 != schedule1 || oldSchedule2 != schedule2 || oldScheduleEnabled != scheduleEnabled ||
      oldWateringSeconds != wateringSeconds || oldNoWaterTimeoutSeconds != noWaterTimeoutSeconds) {
    Serial.print("A runtime settings updated before action: enabled=");
    Serial.print(scheduleEnabled);
    Serial.print(" schedule=");
    Serial.print(schedule1);
    Serial.print("/");
    Serial.print(schedule2);
    Serial.print(" wateringSeconds=");
    Serial.print(wateringSeconds);
    Serial.print(" noWaterTimeout=");
    Serial.println(noWaterTimeoutSeconds);
  }

  if (oldSchedule1 != schedule1 || oldSchedule2 != schedule2) {
    lastScheduleStartKeyA = "";
    lastScheduleSkipKeyA = "";
    manualStoppedScheduleKeyA = "";
    lastNoWaterFaultKeyA = "";
    lastScheduleAttemptMillis = 0;
  }

  saveScheduleSettingsToNVS();
}

