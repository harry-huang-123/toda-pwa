void notifyBoxBAction(const char *action) {
  String msg = "B 區回傳動作：";
  msg.concat(action);
  msg.concat("\n時間：");
  msg.concat(nowString());

  if ((strcmp(action, "valve_on") == 0 || strcmp(action, "on") == 0) && notifyStartWater) {
    sendNtfy("🚿 B 區開始澆水", msg, "droplet");
  } else if ((strcmp(action, "valve_off") == 0 || strcmp(action, "off") == 0) && notifyStopWater) {
    sendNtfy("✅ B 區停止澆水", msg, "white_check_mark");
  } else if (strcmp(action, "water_ok") == 0 && notifyWaterConfirmed) {
    sendNtfy("✅ B 區出水確認", msg, "white_check_mark");
  } else if (strcmp(action, "no_water") == 0 && notifyNoWaterFault) {
    sendNtfy("⚠️ B 區疑似沒有出水", msg, "warning");
  } else if ((strcmp(action, "rain_blocked") == 0 || strcmp(action, "rain_stop") == 0) && notifyRainBlocked) {
    sendNtfy("🌧️ B 區今日因雨滴暫停", msg, "cloud_with_rain");
  }
}

void handleEspNowReceive(const uint8_t *srcAddr, const uint8_t *data, int len) {
  if (len == sizeof(StatusFromB)) {
    uint8_t ownMac[6] = {0};
    getOwnStaMac(ownMac);
    if (macEquals(srcAddr, ownMac)) {
      Serial.println("Ignore ESP-NOW status from own STA MAC");
      return;
    }

    bool wasBoxBOnline = boxBOnline;

    // Learn actual Box B STA MAC from the response. This is more reliable than
    // a hard-coded MAC and fixes the common AP-MAC/STA-MAC off-by-one issue.
    if (memcmp(activeBoxBMac, srcAddr, 6) != 0) {
      memcpy(activeBoxBMac, srcAddr, 6);
      activeBoxBMacLearned = true;
      ensureEspNowPeer(activeBoxBMac);
      printMacAddress("BOX B MAC learned", activeBoxBMac);
    } else {
      activeBoxBMacLearned = true;
    }

    memcpy(&statusB, data, sizeof(statusB));
    if (!validStatusFromBPacket(statusB)) {
      Serial.print("Ignore ESP-NOW status with wrong role/magic from ");
      printMacAddress("", srcAddr);
      return;
    }
    boxBValve = statusB.valve;
    boxBOnline = true;
    boxBRainState = statusB.rain;
    boxBSensorWet = statusB.sensorWet;
    boxBWaterDetected = statusB.waterDetected;
    boxBWateringConfirmed = statusB.wateringConfirmed;
    boxBValveFault = statusB.valveFault;
    boxBRainBlockedToday = statusB.rainBlockedToday;
    boxBWateredToday = statusB.wateredToday;
    boxBWeatherBlocked = statusB.weatherBlocked;
    boxBLocalMode = statusB.localMode;
    boxBLocalAPActive = statusB.localAPActive;
    boxBRemain = statusB.remain;
    boxBScheduleRemainSeconds = statusB.scheduleRemainSeconds;
    boxBNoWaterTimeoutRemainSeconds = statusB.noWaterTimeoutRemainSeconds;
    // 不要讓 Box B 回傳的舊設定覆蓋 Gateway 從 Firebase 讀到的新設定。
    // Box B 只負責回報即時狀態；noWaterTimeoutSeconds / useRainStopRule 以 Firebase -> Box A Gateway 為準。
    boxBHeartbeatSeq = statusB.heartbeatSeq;
    boxBValveActionSeq = statusB.valveActionSeq;
    lastBoxBSeen = millis();
    boxBOfflineNotified = false;
    if (!wasBoxBOnline) {
      char macText[18];
      snprintf(macText, sizeof(macText), "%02X:%02X:%02X:%02X:%02X:%02X",
               srcAddr[0], srcAddr[1], srcAddr[2], srcAddr[3], srcAddr[4], srcAddr[5]);
      Serial.print("BOX B ONLINE via ESP-NOW from ");
      Serial.println(macText);
    }

    if (lastBoxBValveActionSeq != 0 && boxBValveActionSeq != lastBoxBValveActionSeq) {
      notifyBoxBAction(statusB.lastValveAction);
      pushEventForBox("boxB", "espnow_action", statusB.lastValveAction);

      firebasePutString(boxBPath("/lastValveAction"), statusB.lastValveAction);
      firebasePutString(boxBPath("/lastValveActionTime"), nowString());
    }
    lastBoxBValveActionSeq = boxBValveActionSeq;
  } else {
    Serial.print("Unexpected Box B packet size: ");
    Serial.println(len);
  }
}

#if ESP_ARDUINO_VERSION_MAJOR >= 3
void onEspNowReceive(const esp_now_recv_info_t *info, const uint8_t *data, int len) {
  if (!info || !data) return;
  handleEspNowReceive(info->src_addr, data, len);
}
#else
void onEspNowReceive(const uint8_t *mac, const uint8_t *data, int len) {
  if (!mac || !data) return;
  handleEspNowReceive(mac, data, len);
}
#endif


void prepareCommandBProtocol() {
  cmdB.magic = ESPNOW_PROTOCOL_MAGIC;
  cmdB.protocolVersion = ESPNOW_PROTOCOL_VERSION;
  memset(cmdB.sourceBox, 0, sizeof(cmdB.sourceBox));
  memset(cmdB.targetBox, 0, sizeof(cmdB.targetBox));
  strncpy(cmdB.sourceBox, "boxA", sizeof(cmdB.sourceBox) - 1);
  strncpy(cmdB.targetBox, "boxB", sizeof(cmdB.targetBox) - 1);
}

bool validStatusFromBPacket(const StatusFromB &packet) {
  if (packet.magic != ESPNOW_PROTOCOL_MAGIC) return false;
  if (strncmp(packet.sourceBox, "boxB", sizeof(packet.sourceBox)) != 0) return false;
  if (strncmp(packet.targetBox, "boxA", sizeof(packet.targetBox)) != 0) return false;
  return true;
}

void initEspNow() {
  if (espNowReady) return;

  WiFi.setSleep(false);
  esp_err_t initResult = esp_now_init();
  if (initResult != ESP_OK) {
    Serial.print("ESP-NOW init failed code=");
    Serial.println((int)initResult);
    return;
  }

  esp_now_register_recv_cb(onEspNowReceive);
  esp_now_register_send_cb(onEspNowSent);

  uint8_t ownMac[6] = {0};
  getOwnStaMac(ownMac);
  printMacAddress("ESP-NOW own STA MAC", ownMac);

  memset(activeBoxBMac, 0, 6);
  activeBoxBMacLearned = false;
  preferredBoxBMacUsable = (!macIsZero(BOX_B_MAC) && !macEquals(BOX_B_MAC, ownMac));

  if (preferredBoxBMacUsable) {
    memcpy(activeBoxBMac, BOX_B_MAC, 6);
    // Do not mark this as learned yet. A hard-coded MAC may be stale after boards
    // are swapped or reflashed. It becomes learned only after Box B really replies.
    activeBoxBMacLearned = false;
    ensureEspNowPeer(activeBoxBMac);
    printMacAddress("ESP-NOW preferred Box B", activeBoxBMac);
  } else {
    Serial.println("Fixed Box B MAC equals own MAC or is zero; use broadcast discovery only.");
  }

  ensureEspNowPeer(ESP_NOW_BROADCAST_MAC);

  espNowReady = true;
  Serial.println("ESP-NOW peer ready");
  printMacAddress("ESP-NOW broadcast", ESP_NOW_BROADCAST_MAC);
}

void sendCommandToB() {
  if (!espNowReady) return;

  // Keep the latest B settings in every ESP-NOW packet.
  // Box B has no Firebase/NTP; Box A Gateway is the single source of truth.
  cmdB.wateringSeconds = validWateringSeconds(cmdB.wateringSeconds);
  cmdB.noWaterTimeoutSeconds = validWateringSeconds(boxBNoWaterTimeoutSeconds);
  cmdB.useRainStopRule = boxBUseRainStopRule;
  cmdB.weatherBlocked = (weatherBlockedB || boxBWeatherBlocked) && !offlineScheduleBypassBByGateway();
  cmdB.weatherRainProbability = weatherRainProbabilityB;
  cmdB.weatherPrecipitationMM = weatherPrecipitationMMB;
  cmdB.offlineScheduleBypass = offlineScheduleBypassBByGateway();
  cmdB.heartbeatSeq = ++cmdBSeq;
  prepareCommandBProtocol();

  uint8_t ownMac[6] = {0};
  getOwnStaMac(ownMac);

  bool haveUnicastTarget = (!macIsZero(activeBoxBMac) && !macEquals(activeBoxBMac, ownMac));
  if (haveUnicastTarget) {
    ensureEspNowPeer(activeBoxBMac);
    esp_err_t result = esp_now_send(activeBoxBMac, (uint8_t *)&cmdB, sizeof(cmdB));
    espNowUnicastCount++;
    if (result != ESP_OK) {
      Serial.print("ESP-NOW unicast send failed code=");
      Serial.print((int)result);
      Serial.print(" target=");
      printMacAddress("", activeBoxBMac);
    }
  }

  // Discovery packet: while Box B is offline or not learned, broadcast the same command.
  // This makes Box B reply with StatusFromB so Box A can learn the real Box B STA MAC.
  bool needDiscovery = (!activeBoxBMacLearned || !boxBOnline || lastBoxBSeen == 0 || millis() - lastBoxBSeen > 5000UL);
  if (needDiscovery) {
    ensureEspNowPeer(ESP_NOW_BROADCAST_MAC);
    // Broadcast a short burst while Box B is offline. Box B may be channel-hopping,
    // and Firebase HTTPS calls can delay A's loop; multiple broadcasts greatly
    // improve the chance that B catches A when both are on the same channel.
    for (int i = 0; i < 3; i++) {
      esp_err_t bcastResult = esp_now_send(ESP_NOW_BROADCAST_MAC, (uint8_t *)&cmdB, sizeof(cmdB));
      espNowBroadcastCount++;
      if (bcastResult != ESP_OK) {
        Serial.print("ESP-NOW broadcast discovery failed code=");
        Serial.println((int)bcastResult);
      }
      delay(12);
    }
  }

  if (millis() - lastBoxBDebugPrint >= 5000UL) {
    lastBoxBDebugPrint = millis();
    uint8_t ch = 0;
    wifi_second_chan_t second = WIFI_SECOND_CHAN_NONE;
    esp_wifi_get_channel(&ch, &second);
    Serial.print("ESP-NOW B debug ch=");
    Serial.print(ch);
    Serial.print(" online=");
    Serial.print(boxBOnline);
    Serial.print(" learnedMac=");
    Serial.print(activeBoxBMacLearned);
    Serial.print(" sendOK=");
    Serial.print(espNowSendOkCount);
    Serial.print(" sendFAIL=");
    Serial.print(espNowSendFailCount);
    Serial.print(" uni=");
    Serial.print(espNowUnicastCount);
    Serial.print(" bcast=");
    Serial.print(espNowBroadcastCount);
    Serial.print(" target=");
    printMacAddress("", activeBoxBMac);
  }
}

void espNowStartupDiscoveryBurst(const char *reason) {
  Serial.print("ESP-NOW startup discovery burst reason=");
  Serial.println(reason ? reason : "");
  for (int i = 0; i < 40; i++) {
    sendCommandToB();
    delay(50);
  }
}


void clearBoxBOneShotCommand(const char *reason) {
  // v22: Box B actions are one-shot commands.
  // After the short fast-send burst, clear all action bits and requestId so a Box B reboot
  // cannot replay an old ON/OFF/AP/CLEAR command from the next heartbeat.
  cmdB.manualMode = false;
  cmdB.manualValve = false;
  cmdB.autoMode = true;
  cmdB.startWaterRequest = false;
  cmdB.clearTodayStatus = false;
  cmdB.requestLocalAP = false;
  cmdB.offlineScheduleBypass = false;
  cmdB.requestId = 0;
  Serial.print("Clear Box B one-shot command reason=");
  Serial.println(reason ? reason : "");
}

void readSensors() {
  int rainRaw = digitalRead(PIN_RAIN);
  sensorWet = RAIN_SENSOR_ACTIVE_LOW ? (rainRaw == LOW) : (rainRaw == HIGH);

  unsigned long now = millis();
  if (sensorWet) {
    if (sensorWetStartMillis == 0) sensorWetStartMillis = now;
  } else {
    sensorWetStartMillis = 0;
  }

  if (valveState) {
    // 澆水中，雨滴感測器改作出水確認。
    rainState = false;
  } else {
    // 電磁閥關閉時只顯示即時雨滴/潮濕，不提前鎖死今日排程。
    // 是否停止排程，統一在排程觸發前即時判斷。
    waterDetected = false;
    rainState = sensorWet;
  }
}


