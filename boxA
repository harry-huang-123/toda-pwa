  json += BOX_ID;
  json += "\",";
  json += "\"ip\":\"";
  json += WiFi.localIP().toString();
  json += "\",";
  json += "\"rssi\":";
  json += String(WiFi.RSSI());
  json += ",";
  json += "\"valve\":";
  json += valveState ? "true" : "false";
  json += ",";
  json += "\"sensorWet\":";
  json += sensorWet ? "true" : "false";
  json += ",";
  json += "\"fault\":";
  json += valveFault ? "true" : "false";
  json += ",";
  json += "\"boxBOnline\":";
  json += boxBOnline ? "true" : "false";
  json += "}";
  server.send(200, "application/json", json);
}

void setupWebServer() {
  if (webServerStarted) return;
  server.on("/", HTTP_GET, handleRoot);
  server.on("/wifi", HTTP_GET, handleWiFiPage);
  server.on("/wifiscan", HTTP_GET, handleWiFiScanPage);
  server.on("/scanjson", HTTP_GET, handleWiFiScanJson);
  server.on("/savewifi", HTTP_POST, handleSaveWiFi);
  server.on("/on", HTTP_GET, handleOn);
  server.on("/off", HTTP_GET, handleOff);
  server.on("/auto", HTTP_GET, handleAuto);
  server.on("/clear", HTTP_GET, handleClear);
  server.on("/status", HTTP_GET, handleStatus);
  server.on("/ota", HTTP_GET, handleUpdatePage);
  server.on("/update", HTTP_GET, handleUpdatePage);
  server.on("/restart", HTTP_GET, []() {
    server.send(200, "text/plain", "Restarting...");
    delay(500);
    ESP.restart();
  });

  server.on("/update", HTTP_POST, []() {
    server.send(200, "text/plain", Update.hasError() ? "Update failed" : "Update complete. Restarting.");
    delay(1000);
    ESP.restart();
  }, []() {
    HTTPUpload& upload = server.upload();

    if (upload.status == UPLOAD_FILE_START) {
      Update.begin(UPDATE_SIZE_UNKNOWN);
    } else if (upload.status == UPLOAD_FILE_WRITE) {
      Update.write(upload.buf, upload.currentSize);
    } else if (upload.status == UPLOAD_FILE_END) {
      Update.end(true);
    }
  });

  server.onNotFound([]() {
    server.sendHeader("Location", String("http://192.168.4.1/"), true);
    server.send(302, "text/plain", "Redirect to setup page");
  });

  server.begin();
  webServerStarted = true;
  Serial.println("WebServer started on port 80");
}

void setup() {
  Serial.begin(115200);
  delay(1000);

  Serial.println();
  Serial.println("==============================");
  Serial.println("BOX A v23 fast Box B OFF + offline schedule bypass");
  Serial.println("==============================");

  pinMode(PIN_VALVE, OUTPUT);
  digitalWrite(PIN_VALVE, LOW);
  pinMode(PIN_RAIN, INPUT_PULLUP);

  // v19: Do NOT call server.begin() before WiFi.mode()/AP init.
  // ESP32-C3 can assert in xQueueSemaphoreTake if WebServer starts before WiFi stack is ready.
  loadScheduleSettingsFromNVS();
  wifiOK = connectWiFi();

  if (!wifiOK) {
    Serial.println("WiFi not connected. Start Setup-boxA AP on fallback channel. Router WiFi setup can still scan/connect other channels.");
    WiFi.mode(WIFI_STA);
    WiFi.setSleep(false);
    esp_wifi_set_ps(WIFI_PS_NONE);
    esp_wifi_set_channel(ESPNOW_WIFI_CHANNEL, WIFI_SECOND_CHAN_NONE);
    if (BOXA_AUTO_START_AP_WHEN_WIFI_FAIL) startAPMode();
    // v19: Start WebServer only after WiFi/AP is initialized.
    setupWebServer();
    initEspNow();
    espNowStartupDiscoveryBurst("offline_boot");
  } else {
    Serial.print("IP: ");
    Serial.println(WiFi.localIP());
    Serial.print("RSSI: ");
    Serial.println(WiFi.RSSI());
    Serial.print("WiFi channel: ");
    Serial.println(WiFi.channel());

    // v19: WebServer is safe after WiFi is connected.
    setupWebServer();
    MDNS.begin(HOSTNAME);
    configTime(8 * 3600, 0, "pool.ntp.org", "time.nist.gov");
    waitForTimeSync();

    initFirebase();
    primeCommandSeqsFromFirebase("wifi_boot_no_replay");
    initEspNow();
    espNowStartupDiscoveryBurst("wifi_boot_after_prime_no_replay");
    readFirebaseSettings();
    uploadStatus();
    readNotifySettings();
    fetchWeatherForBox("boxA");
    delay(1000);
    fetchWeatherForBox("boxB");
    lastWeatherFetch = millis();
    sendNtfy("✅ A 區上線", "Box A Gateway connected to WiFi", "white_check_mark");
  }

  setupWebServer();  // guarded; safe fallback only after WiFi/AP init
}

void loop() {
  server.handleClient();

  unsigned long now = millis();

  // Highest priority: read manual Firebase commands first.
  if (wifiOK && now - lastFastCommandRead >= FAST_COMMAND_INTERVAL_MS) {
    lastFastCommandRead = now;
    readFastCommand();
  }

  if (WiFi.status() != WL_CONNECTED && now - lastWiFiReconnect >= WIFI_RECONNECT_INTERVAL_MS) {
    lastWiFiReconnect = now;

    // v11 speed fix:
    // When Setup-boxA AP is active, do NOT run background WiFi scan/reconnect.
    // connectWiFi() performs scan + connect waits and can freeze/drop the AP page.
    // WiFi reconnect is done after the user saves WiFi and the device restarts.
    if (apRunning) {
      wifiOK = false;
      Serial.println("Setup-boxA AP active. Skip background WiFi reconnect to keep AP web page fast.");
    } else if (apConfigHoldActive()) {
      Serial.println("AP setup page active. Skip background WiFi reconnect to keep Setup-boxA responsive.");
    } else {
      Serial.println("WiFi disconnected. Reconnecting...");
      wifiOK = connectWiFi();
      if (wifiOK) {
        Serial.println("WiFi reconnect SUCCESS");
        configTime(8 * 3600, 0, "pool.ntp.org", "time.nist.gov");
        waitForTimeSync();
        initFirebase();
        initEspNow();
        readFirebaseSettings();
        primeCommandSeqsFromFirebase("wifi_reconnect_no_replay");
        uploadStatus();
        if (apRunning) startAPMode();
      } else {
        Serial.println("WiFi reconnect FAILED. Keep/start Setup-boxA AP on fallback channel.");
        WiFi.mode(WIFI_STA);
        WiFi.setSleep(false);
        esp_wifi_set_channel(ESPNOW_WIFI_CHANNEL, WIFI_SECOND_CHAN_NONE);
        if (BOXA_AUTO_START_AP_WHEN_WIFI_FAIL && !apRunning) startAPMode();
        initEspNow();
      }
    }
  }

  if (now - lastSensorRead >= 1000) {
    lastSensorRead = now;
    readSensors();
  }


  if (now - lastControlLogicA >= 1000UL) {
    lastControlLogicA = now;
    controlLogicA();
    controlLogicBByGateway();
  }

  // ESP-NOW must keep running even when Firebase/WiFi is slow or offline.
  // This also lets Box B catch Box A while it is hopping channels.
  unsigned long espNowInterval = boxBOnline ? 1000UL : BOXB_ESPNOW_SEND_INTERVAL_MS;
  if (espNowReady && now - lastBoxBCommandSend >= espNowInterval) {
    lastBoxBCommandSend = now;
    sendCommandToB();
  }

  if (wifiOK && now - lastFirebaseSync >= HEARTBEAT_INTERVAL_MS) {
    lastFirebaseSync = now;
    uploadStatus();
    controlLogicA();
    sendCommandToB();
  }

  if (wifiOK && now - lastSettingsRead >= SETTINGS_READ_INTERVAL_MS) {
    lastSettingsRead = now;
    readFirebaseSettings();
    controlLogicA();
    sendCommandToB();
  }

  if (wifiOK && now - lastNotifySettingsRead >= NOTIFY_SETTINGS_READ_INTERVAL_MS) {
    lastNotifySettingsRead = now;
    readNotifySettings();
  }

  if (wifiOK && now - lastWeatherFetch >= WEATHER_FETCH_INTERVAL_MS) {
    lastWeatherFetch = now;
    fetchWeatherForBox("boxA");
    delay(1000);
    fetchWeatherForBox("boxB");
  }

  if (apRunning && millis() - apStartMillis >= AP_ACTIVE_TIME_MS) {
    if (WiFi.status() == WL_CONNECTED) {
      stopAPMode();
      initEspNow();
    } else {
      apStartMillis = millis();
      Serial.println("No router WiFi. Keep Setup-boxA AP active for setup and ESP-NOW same-channel operation.");
    }
  }

  bool boxBTimedOut = (lastBoxBSeen == 0 || millis() - lastBoxBSeen > BOXB_TIMEOUT_MS);
  if (boxBTimedOut) {
    boxBOnline = false;
    boxBRemain = 0;
    if (!boxBOfflineNotified && notifyOffline && wifiOK) {
      boxBOfflineNotified = true;
      String msg = "Box B 超過時間沒有回傳 heartbeat\n時間：";
      msg.concat(nowString());
      sendNtfy("⚠️ Box B 離線", msg, "warning");
    }
  }

  if (now - lastHeapPrint >= 10000) {
    lastHeapPrint = now;
    Serial.print("Free heap: ");
    Serial.println(ESP.getFreeHeap());
    if (WiFi.status() == WL_CONNECTED) {
      Serial.print("RSSI: ");
      Serial.println(WiFi.RSSI());
    }
  }
}
