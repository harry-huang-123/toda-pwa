String firebaseUrl(String path, bool silentWrite = false) {
  String url = DATABASE_URL;
  if (!url.endsWith("/")) url.concat("/");
  if (path.startsWith("/")) path.remove(0, 1);
  url.concat(path);
  url.concat(".json");
  if (silentWrite) url.concat("?print=silent");
  return url;
}

bool firebaseRequestRaw(const char *method, String path, String body, String &payload) {
  if (WiFi.status() != WL_CONNECTED) return false;

  WiFiClientSecure client;
  client.setInsecure();

  HTTPClient http;
  bool isWrite = (strcmp(method, "PUT") == 0 || strcmp(method, "PATCH") == 0 || strcmp(method, "POST") == 0);
  String url = firebaseUrl(path, isWrite);

  if (!http.begin(client, url)) {
    Serial.print("Firebase begin failed: ");
    Serial.println(url);
    return false;
  }

  http.setReuse(false);
  http.addHeader("Content-Type", "application/json");

  int code = -1;
  if (strcmp(method, "GET") == 0) {
    code = http.GET();
  } else if (strcmp(method, "PUT") == 0) {
    code = http.PUT(body);
  } else if (strcmp(method, "PATCH") == 0) {
    code = http.PATCH(body);
  } else if (strcmp(method, "POST") == 0) {
    code = http.POST(body);
  }

  payload = http.getString();
  http.end();
  client.stop();

  if (code < 200 || code >= 300) {
    Serial.print("Firebase ");
    Serial.print(method);
    Serial.print(" failed code=");
    Serial.print(code);
    Serial.print(" path=");
    Serial.println(path);
    if (payload.length() > 0) {
      Serial.print("payload=");
      Serial.println(payload);
    }
    return false;
  }

  return true;
}

bool firebaseGetRaw(String path, String &payload) {
  String empty = "";
  return firebaseRequestRaw("GET", path, empty, payload) && payload != "null";
}

bool firebasePutRaw(String path, String jsonValue) {
  String payload;
  return firebaseRequestRaw("PUT", path, jsonValue, payload);
}

bool firebasePatchRaw(String path, String jsonObject) {
  String payload;
  return firebaseRequestRaw("PATCH", path, jsonObject, payload);
}

bool firebasePostRaw(String path, String jsonObject) {
  String payload;
  return firebaseRequestRaw("POST", path, jsonObject, payload);
}

bool firebasePutBool(String path, bool value) {
