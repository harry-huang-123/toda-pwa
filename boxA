void fetchWeatherForBox(const char *boxId) {
  if (WiFi.status() != WL_CONNECTED) return;

  Serial.println();
  Serial.print("========== Weather Fetch ");
  Serial.print(boxId);
  Serial.println(" ==========");

  String locationName = "Custom";
  double latitude = 22.6273;
  double longitude = 120.3014;
  bool ruleEnabled = true;
  int rainLimit = 60;
  float precipLimit = 2.0;
  readWeatherSettingsForBox(boxId, locationName, latitude, longitude, ruleEnabled, rainLimit, precipLimit);

  String url = "http://api.open-meteo.com/v1/forecast?latitude=";
  url.concat(String(latitude, 6));
  url.concat("&longitude=");
  url.concat(String(longitude, 6));
  url.concat("&daily=precipitation_sum,precipitation_probability_max,weather_code,temperature_2m_max,temperature_2m_min");
  url.concat("&timezone=Asia%2FTaipei&forecast_days=1");

  HTTPClient http;
  Serial.print("Weather URL: ");
  Serial.println(url);

  if (!http.begin(url)) {
    Serial.println("Weather HTTP begin failed");
    return;
  }

  http.setReuse(false);
  int code = http.GET();
  Serial.print("Weather HTTP code: ");
  Serial.println(code);

  if (code != 200) {
    String errorPayload = http.getString();
    Serial.print("Weather error payload: ");
    Serial.println(errorPayload);
    http.end();
    return;
  }

  String payload = http.getString();
  http.end();

  DynamicJsonDocument doc(8192);
  DeserializationError err = deserializeJson(doc, payload);
  if (err) {
    Serial.print("Weather JSON error: ");
    Serial.println(err.c_str());
    return;
  }

  float precipitationMM = doc["daily"]["precipitation_sum"][0] | 0.0;
  int rainProbability = doc["daily"]["precipitation_probability_max"][0] | 0;
  int weatherCode = doc["daily"]["weather_code"][0] | 0;
  float tempMax = doc["daily"]["temperature_2m_max"][0] | 0.0;
  float tempMin = doc["daily"]["temperature_2m_min"][0] | 0.0;
  float temperature = (tempMax + tempMin) / 2.0;

  bool blockWatering = false;
  if (ruleEnabled) {
    blockWatering = (rainProbability >= rainLimit || precipitationMM >= precipLimit);
  }

  String blockReason;
  if (!ruleEnabled) {
    blockReason = "此區未啟用天氣預報限制";
  } else if (blockWatering) {
    blockReason = "降雨機率或預估雨量超過設定門檻";
  } else {
    blockReason = "目前預報條件允許自動澆水";
  }

  DynamicJsonDocument out(1024);
  out["location"] = locationName;
  out["latitude"] = latitude;
  out["longitude"] = longitude;
  out["weatherText"] = weatherCodeToText(weatherCode);
  out["weatherCode"] = weatherCode;
  out["temperature"] = temperature;
  out["rainProbability"] = rainProbability;
  out["precipitationMM"] = precipitationMM;
  out["blockWatering"] = blockWatering;
  out["blockReason"] = blockReason;
  out["updatedAt"] = nowString();

  String weatherJson;
  serializeJson(out, weatherJson);

  String weatherPath = "/weather/today/";
  weatherPath.concat(boxId);
  bool uploadOk = firebasePutRaw(weatherPath, weatherJson);

  String boxWeatherPath = "/boxes/";
  boxWeatherPath.concat(boxId);
  boxWeatherPath.concat("/weatherBlocked");
  firebasePutBool(boxWeatherPath, blockWatering);

  if (strcmp(boxId, "boxA") == 0) {
    weatherBlockedA = blockWatering;
    if (weatherBlockedA && !lastWeatherBlockedA && notifyWeatherBlocked) {
      String msg = "A 區今日天氣預報不適合自動澆水\n降雨機率：";
      msg.concat(String(rainProbability));
      msg.concat("%\n預估雨量：");
      msg.concat(String(precipitationMM, 1));
      msg.concat(" mm\n時間：");
      msg.concat(nowString());
      sendNtfy("🌧️ A 區天氣預報暫停澆水", msg, "cloud_with_rain");
    }
    lastWeatherBlockedA = weatherBlockedA;
  }

  if (strcmp(boxId, "boxB") == 0) {
    weatherBlockedB = blockWatering;
    weatherRainProbabilityB = rainProbability;
    weatherPrecipitationMMB = precipitationMM;
    if (weatherBlockedB && !lastWeatherBlockedB && notifyWeatherBlocked) {
      String msg = "B 區今日天氣預報不適合自動澆水\n降雨機率：";
      msg.concat(String(rainProbability));
      msg.concat("%\n預估雨量：");
      msg.concat(String(precipitationMM, 1));
      msg.concat(" mm\n時間：");
      msg.concat(nowString());
      sendNtfy("🌧️ B 區天氣預報暫停澆水", msg, "cloud_with_rain");
    }
    lastWeatherBlockedB = weatherBlockedB;
  }

  Serial.print("Weather updated for ");
  Serial.print(boxId);
  Serial.print(" rain=");
  Serial.print(rainProbability);
  Serial.print("% precipitation=");
  Serial.print(precipitationMM);
  Serial.print("mm block=");
  Serial.print(blockWatering ? "true" : "false");
  Serial.print(" upload=");
  Serial.println(uploadOk ? "success" : "failed");
}
void readNotifySettings() {
  String payload;
  if (!firebaseGetRaw("/settings/notify", payload)) return;

  StaticJsonDocument<1024> doc;
  DeserializationError err = deserializeJson(doc, payload);
  if (err) return;

  if (doc["enabled"].is<bool>()) ntfyEnabled = doc["enabled"].as<bool>();
  if (doc["topic"].is<const char *>()) {
    String t = doc["topic"].as<const char *>();
    t.trim();
    if (t.length() > 0) ntfyTopic = t;
  }
  if (doc["startWater"].is<bool>()) notifyStartWater = doc["startWater"].as<bool>();
  if (doc["stopWater"].is<bool>()) notifyStopWater = doc["stopWater"].as<bool>();
  if (doc["waterConfirmed"].is<bool>()) notifyWaterConfirmed = doc["waterConfirmed"].as<bool>();
  if (doc["noWaterFault"].is<bool>()) notifyNoWaterFault = doc["noWaterFault"].as<bool>();
  if (doc["rainBlocked"].is<bool>()) notifyRainBlocked = doc["rainBlocked"].as<bool>();
  if (doc["offline"].is<bool>()) notifyOffline = doc["offline"].as<bool>();
  if (doc["weatherBlocked"].is<bool>()) notifyWeatherBlocked = doc["weatherBlocked"].as<bool>();
}
void sendNtfy(const String &title, const String &message, const String &tags) {
  if (!ntfyEnabled) return;
  if (ntfyTopic.length() == 0) return;
  if (WiFi.status() != WL_CONNECTED) return;

  WiFiClientSecure client;
  client.setInsecure();

  HTTPClient https;
  String url = buildNtfyUrl();
  if (!https.begin(client, url)) {
    Serial.println("ntfy begin failed");
    return;
  }

  https.addHeader("Content-Type", "text/plain; charset=utf-8");
  https.addHeader("Title", title);
  https.addHeader("Tags", tags);
  https.addHeader("Priority", "default");

  int code = https.POST(message);
  Serial.print("ntfy code: ");
  Serial.println(code);

  https.end();
}
