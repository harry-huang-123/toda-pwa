int hhmmToMinutes(const String &value) {
  if (value.length() < 5) return -1;
  int colon = value.indexOf(':');
  if (colon <= 0) return -1;
  int h = value.substring(0, colon).toInt();
  int m = value.substring(colon + 1).toInt();
  if (h < 0 || h > 23 || m < 0 || m > 59) return -1;
  return h * 60 + m;
}

int currentMinutesOfDay() {
  String nowHM = currentHHMM();
  return hhmmToMinutes(nowHM);
}

bool scheduleMinuteInWindow(int nowMin, int targetMin, int windowMin = 3) {
  if (nowMin < 0 || targetMin < 0) return false;
  int diff = (nowMin - targetMin + 1440) % 1440;
  return diff >= 0 && diff <= windowMin;
}

bool scheduleTimeMatchesNow(const String &targetHHMM) {
  // Box C-style strict 24-hour schedule matching.
  // 15:59 only matches 15:59; it will not also match 03:59.
  int nowMin = currentMinutesOfDay();
  int targetMin = hhmmToMinutes(targetHHMM);
  if (nowMin < 0 || targetMin < 0) return false;
  return scheduleMinuteInWindow(nowMin, targetMin, 3);
}

