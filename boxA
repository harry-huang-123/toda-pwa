void printMacAddress(const char *label, const uint8_t *mac) {
  char buf[18];
  snprintf(buf, sizeof(buf), "%02X:%02X:%02X:%02X:%02X:%02X",
           mac[0], mac[1], mac[2], mac[3], mac[4], mac[5]);
  if (label && strlen(label) > 0) {
    Serial.print(label);
    Serial.print(": ");
  }
  Serial.println(buf);
}

void getOwnStaMac(uint8_t *mac) {
  if (!mac) return;
  esp_wifi_get_mac(WIFI_IF_STA, mac);
}

bool macEquals(const uint8_t *a, const uint8_t *b) {
  if (!a || !b) return false;
  return memcmp(a, b, 6) == 0;
}

bool macIsZero(const uint8_t *mac) {
  if (!mac) return true;
  for (int i = 0; i < 6; i++) {
    if (mac[i] != 0) return false;
  }
  return true;
}

bool macIsBroadcast(const uint8_t *mac) {
  if (!mac) return false;
  for (int i = 0; i < 6; i++) {
    if (mac[i] != 0xFF) return false;
  }
  return true;
}


uint8_t currentRadioChannelA() {
  uint8_t ch = 0;
  wifi_second_chan_t second = WIFI_SECOND_CHAN_NONE;
  if (esp_wifi_get_channel(&ch, &second) == ESP_OK && ch >= 1 && ch <= 13) return ch;
  if (WiFi.status() == WL_CONNECTED && WiFi.channel() >= 1 && WiFi.channel() <= 13) return (uint8_t)WiFi.channel();
  return ESPNOW_WIFI_CHANNEL;
}

wifi_interface_t currentEspNowIfidxA() {
  // v20 critical fix:
  // When Box A is only running Setup-boxA AP and is not connected to router WiFi,
  // ESP-NOW must use the AP interface. Using WIFI_IF_STA here can make A transmit fail
  // while the phone can still connect to Setup-boxA.
  if (apRunning && WiFi.status() != WL_CONNECTED) return WIFI_IF_AP;
  return WIFI_IF_STA;
}

bool ensureEspNowPeer(const uint8_t *mac) {
  if (!mac) return false;

  uint8_t ch = currentRadioChannelA();
  wifi_interface_t ifidx = currentEspNowIfidxA();

  // If the router/AP channel or interface changes, the old peer becomes stale.
  // Recreate peers when channel OR ifidx changes.
  if (esp_now_is_peer_exist(mac)) {
    if (lastEspNowPeerChannel == ch && lastEspNowPeerIfidx == ifidx) return true;
    esp_now_del_peer(mac);
  }

  esp_now_peer_info_t peerInfo = {};
  memcpy(peerInfo.peer_addr, mac, 6);
  peerInfo.channel = ch;
  peerInfo.encrypt = false;
  peerInfo.ifidx = ifidx;

  esp_err_t result = esp_now_add_peer(&peerInfo);
  Serial.print("ESP-NOW add peer currentCh=");
  Serial.print(ch);
  Serial.print(" ifidx=");
  Serial.print(ifidx == WIFI_IF_AP ? "AP" : "STA");
  Serial.print(" mac=");
  printMacAddress("", mac);
  Serial.print(" result=");
  Serial.println(result == ESP_OK ? "OK" : String((int)result));

  if (result == ESP_OK || result == ESP_ERR_ESPNOW_EXIST) {
    lastEspNowPeerChannel = ch;
    lastEspNowPeerIfidx = ifidx;
    return true;
  }
  return false;
}

