void forceValveImmediate(bool on, const char *reason) {
  // Highest-priority manual GPIO path: do hardware action first, no Firebase/ntfy/event before GPIO.
  pinMode(PIN_VALVE, OUTPUT);
  digitalWrite(PIN_VALVE, on ? HIGH : LOW);

  Serial.print("GPIO");
  Serial.print(PIN_VALVE);
  Serial.print(" IMMEDIATE ");
  Serial.print(on ? "HIGH" : "LOW");
  Serial.print(" reason=");
  Serial.print(reason ? reason : "");
  Serial.print(" readback=");
  Serial.println(digitalRead(PIN_VALVE));

  if (valveState != on) {
    valveState = on;
    valveActionSeq++;
    if (on) {
      valveStartMillis = millis();
      waterDetected = false;
      wateringConfirmed = false;
      valveFault = false;
      faultReason = "";
    } else {
      lastWaterEndMillis = millis();
    }
  }

  statusDirty = true;
}

void setValve(bool on, String reason = "") {
  // Always force GPIO4 to the requested level, even if the software state already says ON/OFF.
  // This makes hardware testing reliable after reset or after a missed command.
  pinMode(PIN_VALVE, OUTPUT);
  digitalWrite(PIN_VALVE, on ? HIGH : LOW);

  Serial.print("GPIO");
  Serial.print(PIN_VALVE);
  Serial.print(" forced ");
  Serial.print(on ? "HIGH" : "LOW");
  Serial.print(" reason=");
  Serial.print(reason);
  Serial.print(" readback=");
  Serial.println(digitalRead(PIN_VALVE));

  if (valveState == on) {
    firebasePutBool(ownPath("/valve"), on);
    firebasePutString(ownPath("/lastGPIOLevel"), on ? "HIGH" : "LOW");
    return;
  }

  valveState = on;
  firebasePutBool(ownPath("/valve"), valveState);
  firebasePutString(ownPath("/lastGPIOLevel"), on ? "HIGH" : "LOW");

  if (on) {
    valveStartMillis = millis();
    waterDetected = false;
    wateringConfirmed = false;
    valveFault = false;
    faultReason = "";
    updateLastValveAction("valve_on", reason);

    firebasePutString(ownPath("/lastWaterTime"), nowString());
    firebasePutString(ownPath("/lastWaterReason"), reason);
    firebasePutBool(ownPath("/waterDetected"), false);
    firebasePutBool(ownPath("/wateringConfirmed"), false);
    firebasePutBool(ownPath("/valveFault"), false);
    firebasePutString(ownPath("/faultReason"), "");

    String msg = "boxA start watering. Reason: ";
    msg.concat(reason);
    pushEvent("water_start", msg);

    if (notifyStartWater) {
      String body = "原因：";
      body.concat(reason);
      body.concat("\n時間：");
      body.concat(nowString());
      sendNtfy("🚿 A 區開始澆水", body, "droplet");
    }
  } else {
    lastWaterEndMillis = millis();
    updateLastValveAction("valve_off", reason);

    String msg = "boxA stop watering. Reason: ";
    msg.concat(reason);
    pushEvent("water_stop", msg);

    if (notifyStopWater) {
      String body = "原因：";
      body.concat(reason);
      body.concat("\n時間：");
      body.concat(nowString());
      sendNtfy("✅ A 區停止澆水", body, "white_check_mark");
    }
  }
}

