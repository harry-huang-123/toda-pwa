bool waitForTimeSync() {
  Serial.println("Waiting NTP time sync...");
  struct tm timeinfo;
  unsigned long start = millis();
  while (millis() - start < 15000) {
    if (getLocalTime(&timeinfo)) {
      Serial.print("NTP time sync SUCCESS: ");
      Serial.println(nowString());
      return true;
    }
    delay(500);
    Serial.print(".");
  }
  Serial.println();
  Serial.println("NTP time sync FAILED");
  return false;
}

void readWeatherSettingsForBox(const char *boxId, String &locationName, double &latitude, double &longitude,
                               bool &ruleEnabled, int &rainLimit, float &precipLimit) {
  String settingPath = "/settings/weather/";
  settingPath.concat(boxId);

  String payload;
  if (!firebaseGetRaw(settingPath, payload)) {
    Serial.print("Weather settings not found for ");
    Serial.println(boxId);
    return;
  }

  DynamicJsonDocument doc(1024);
  DeserializationError err = deserializeJson(doc, payload);
  if (err) {
    Serial.print("Weather settings JSON error: ");
    Serial.println(err.c_str());
    return;
  }

  if (doc["locationName"].is<const char *>()) locationName = doc["locationName"].as<const char *>();
  if (doc["latitude"].is<double>()) latitude = doc["latitude"].as<double>();
  if (doc["longitude"].is<double>()) longitude = doc["longitude"].as<double>();
  if (doc["useWeatherRule"].is<bool>()) ruleEnabled = doc["useWeatherRule"].as<bool>();
  if (doc["maxRainProbability"].is<int>()) rainLimit = doc["maxRainProbability"].as<int>();
  if (doc["maxPrecipitationMM"].is<float>()) precipLimit = doc["maxPrecipitationMM"].as<float>();
}
