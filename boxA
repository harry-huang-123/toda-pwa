bool firebasePutString(String path, String value) {
  String jsonValue;
  jsonValue.reserve(value.length() + 2);
  jsonValue.concat("\"");
  jsonValue.concat(jsonEscape(value));
  jsonValue.concat("\"");
  return firebasePutRaw(path, jsonValue);
}

