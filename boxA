  pushEvent("schedule_window_handled", String("A區目前時間仍在排程觸發視窗內，此時段已標記為處理完成，不補做。key=") + key + " reason=" + reason);
}

void markCurrentScheduleHandledA(const String &reason) {
  if (!currentWateringFromScheduleA || currentScheduleKeyA.length() == 0) return;
  manualStoppedScheduleKeyA = currentScheduleKeyA;
  lastScheduleStartKeyA = currentScheduleKeyA;
  lastScheduleSkipKeyA = currentScheduleKeyA;
  Serial.print("SCHEDULE A SLOT RECORDED AS HANDLED: ");
  Serial.print(currentScheduleKeyA);
  Serial.print(" reason=");
  Serial.println(reason);
  pushEvent("schedule_slot_handled", String("A區排程時段已記錄完成，不會重複啟動。key=") + currentScheduleKeyA + " reason=" + reason);
  currentWateringFromScheduleA = false;
  currentScheduleKeyA = "";
}

int scheduleRemainSecondsA() {
  if (!valveState || !currentWateringFromScheduleA) return 0;
  unsigned long elapsed = (millis() - valveStartMillis) / 1000UL;
  if (elapsed >= (unsigned long)wateringSeconds) return 0;
  return wateringSeconds - (int)elapsed;
}

int noWaterTimeoutRemainSecondsA() {
  if (!valveState || wateringConfirmed) return 0;
  unsigned long elapsed = (millis() - valveStartMillis) / 1000UL;
  int timeoutSec = noWaterTimeoutSeconds < 1 ? 1 : noWaterTimeoutSeconds;
  if (elapsed >= (unsigned long)timeoutSec) return 0;
  return timeoutSec - (int)elapsed;
}

bool wifiConnectedNowA() {
  return wifiOK && WiFi.status() == WL_CONNECTED;
}

bool offlineScheduleBypassA() {
  return offlineScheduleContinue && !wifiConnectedNowA();
}

bool rainSensorShouldBlockScheduleNowA(unsigned long now) {
  (void)now;
  if (!useRainStopRule) return false;
  // A 區與 Box C 一樣：只在排程準備啟動前即時檢查雨滴感測器。
  // 排程啟動後 sensorWet 改作出水確認，不會立刻停止排程。
  return sensorWet;
}

bool canScheduleWaterA() {
  if (manualMode && manualValve) return false;
  if (offlineScheduleBypassA()) return true;
  if (valveFault) return false;
  // 雨滴/潮濕不在這裡用 rainBlockedToday 永久阻擋。
  // 真正判斷點在排程啟動前 rainSensorShouldBlockScheduleNowA(now)。
  if (useWeatherRule && weatherBlockedA) return false;
  return true;
}

