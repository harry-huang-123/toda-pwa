void controlLogicA() {
  String today = todayString();
  if (today != "unknown" && today != lastDayState) {
    lastDayState = today;
    rainBlockedToday = false;
    wateredToday = false;
    wateringConfirmed = false;
    waterDetected = false;
    valveFault = false;
    faultReason = "";
    lastScheduleStartKeyA = "";
    lastScheduleSkipKeyA = "";
    lastNoWaterFaultKeyA = "";
    manualStoppedScheduleKeyA = "";
  }

  unsigned long now = millis();

  // 雨滴/潮濕只在排程準備啟動前判斷，不在平常提前鎖死今日排程。
  if (!rainState) rainWetStartMillis = 0;

  if (manualMode && manualValve) {
    if (!valveState) {
      valveFault = false;
      faultReason = "";
      waterDetected = false;
      wateringConfirmed = false;
      forceValveImmediate(true, "manual_control_sync_on");
      updateLastValveAction("manual_control_sync_on", "manual sync on");
    }
  }

  // Stop conditions must run before schedule re-check, same as Box C.
  if (valveState) {
    bool fromSchedule = currentWateringFromScheduleA;
    bool fromManual = manualMode;

    if (sensorWet && sensorWetStartMillis > 0 && now - sensorWetStartMillis >= RAIN_BLOCK_CONFIRM_MS && !wateringConfirmed) {
      markWaterConfirmed();
      firebasePutInt(ownPath("/noWaterTimeoutRemainSeconds"), 0);
    }

    bool offlineScheduleRunA = fromSchedule && offlineScheduleBypassA();

    if ((fromSchedule || fromManual) && !offlineScheduleRunA && !wateringConfirmed && now - valveStartMillis >= noWaterTimeoutMsA()) {
      String faultKey = currentScheduleKeyA.length() > 0 ? currentScheduleKeyA : String(millis());
      bool wasSchedule = fromSchedule;
      bool wasManual = fromManual;

      if (wasSchedule) markCurrentScheduleHandledA("schedule_no_water_fault_recorded");
      currentWateringFromScheduleA = false;
      currentScheduleKeyA = "";
      manualMode = false;
      manualValve = false;
      autoMode = true;
      waterDetected = false;
      wateringConfirmed = false;
      valveFault = true;
      faultReason = "no water detected within timeout";
      if (wasSchedule) scheduleEnabled = false;

      forceValveImmediate(false, "fault_off");
      updateLastValveAction("fault_off", faultReason);
      Serial.println("Valve fault: no water detected within timeout, valve forced OFF before schedule re-check");

      firebasePutBool(ownPath("/valve"), false);
      firebasePutBool(ownPath("/desiredValve"), false);
      firebasePutBool(ownPath("/manualMode"), false);
      firebasePutBool(ownPath("/manualValve"), false);
      firebasePutBool(ownPath("/waterDetected"), false);
      firebasePutBool(ownPath("/wateringConfirmed"), false);
      firebasePutInt(ownPath("/scheduleRemainSeconds"), 0);
      firebasePutInt(ownPath("/noWaterTimeoutRemainSeconds"), 0);
      firebasePutBool(ownPath("/valveFault"), true);
      firebasePutString(ownPath("/faultReason"), faultReason);
      if (wasSchedule) firebasePutBool(ownPath("/scheduleEnabled"), false);

      if (wasSchedule && faultKey != lastNoWaterFaultKeyA) {
        lastNoWaterFaultKeyA = faultKey;
        pushEvent("schedule_no_water_fault", String("A區排程澆水啟用後 ") + String(noWaterTimeoutSeconds) + " 秒內沒有穩定偵測到水，已強制關閉電磁閥、關閉排程模式，並將排程秒數清零。");
      } else if (wasManual) {
        pushEvent("manual_no_water_fault", String("A區手動澆水開啟後 ") + String(noWaterTimeoutSeconds) + " 秒內沒有穩定偵測到水，已自動關閉電磁閥並離開手動模式。");
      }
      if (notifyNoWaterFault) sendNtfy("⚠️ A 區無水故障", "A區出水偵測逾時，已自動關閉電磁閥。", "warning");
      statusDirty = true;
      return;
    }

    if (fromSchedule && now - valveStartMillis >= (unsigned long)wateringSeconds * 1000UL) {
      wateredToday = true;
      markCurrentScheduleHandledA("schedule_watering_done_recorded");
      currentWateringFromScheduleA = false;
      currentScheduleKeyA = "";
      waterDetected = false;
      wateringConfirmed = false;
      forceValveImmediate(false, "time_off");
      updateLastValveAction("time_off", "schedule watering done");
      firebasePutBool(ownPath("/valve"), false);
      firebasePutBool(ownPath("/desiredValve"), false);
      firebasePutInt(ownPath("/scheduleRemainSeconds"), 0);
      firebasePutInt(ownPath("/noWaterTimeoutRemainSeconds"), 0);
      pushEvent("schedule_done", String("A區排程澆水完成，已澆水 ") + String(wateringSeconds) + " 秒。此時段已記錄，不會重複啟動。");
      statusDirty = true;
      return;
    }
  }

  // manualMode=true + manualValve=false means 手動排程模式；仍允許排程。
  if (!(manualMode && manualValve)) {
    if (now - lastScheduleWatchPrintA >= 10000UL) {
      lastScheduleWatchPrintA = now;
      printScheduleWatchA();
    }

    String slot = matchedScheduleSlotA();
    if (scheduleEnabled && slot.length() > 0) {
      String scheduleKey = makeScheduleKeyA(slot);
      if (scheduleKey == lastScheduleStartKeyA || scheduleKey == lastScheduleSkipKeyA || scheduleKey == manualStoppedScheduleKeyA) {
        if (lastValveActionStr != "schedule_slot_already_handled") {
          Serial.print("SCHEDULE A SKIP: slot already handled key=");
          Serial.println(scheduleKey);
        }
        lastValveActionStr = "schedule_slot_already_handled";
        return;
      }

      if (!valveState && now - lastScheduleAttemptMillis >= SCHEDULE_RETRY_INTERVAL_MS) {
        lastScheduleAttemptMillis = now;
        if (!offlineScheduleBypassA() && rainSensorShouldBlockScheduleNowA(now)) {
          rainBlockedToday = true;
          rainState = true;
          lastScheduleSkipKeyA = scheduleKey;
          updateLastValveAction("schedule_skip_sensor_wet_before_start", "rain sensor wet before schedule start");
          pushEvent("schedule_skip_sensor_wet_before_start", "A區排程時間到，但雨滴/潮濕感測器在電磁閥尚未開啟前已偵測到濕潤，因此本時段不啟動澆水。");
          if (notifyRainBlocked) sendNtfy("🌧️ A 區雨滴暫停", "A區排程時間到，但澆水前已偵測到雨滴/潮濕，已停止本次排程澆水。", "umbrella");
          firebasePutBool(ownPath("/rainBlockedToday"), true);
          firebasePutBool(ownPath("/rain"), true);
          firebasePutInt(ownPath("/scheduleRemainSeconds"), 0);
          firebasePutInt(ownPath("/noWaterTimeoutRemainSeconds"), 0);
          statusDirty = true;
          return;
        } else if (!canScheduleWaterA()) {
          lastScheduleSkipKeyA = scheduleKey;
          updateLastValveAction("schedule_skip_blocked", "weather/fault/manual block");
          pushEvent("schedule_skip_blocked", "A區排程時間到但條件阻擋，未啟動澆水。請確認天氣、故障或手動狀態。");
          if (notifyRainBlocked || notifyWeatherBlocked || notifyNoWaterFault) sendNtfy("⚠️ A 區排程未啟動", "A區排程時間到但條件阻擋，未啟動澆水。請確認天氣、故障或手動狀態。", "warning");
          statusDirty = true;
          return;
        } else {
          currentWateringFromScheduleA = true;
          currentScheduleKeyA = scheduleKey;
          Serial.print("SCHEDULE A START: valve ON, noWaterTimeout=");
          Serial.print(noWaterTimeoutSeconds);
          Serial.print("s wateringSeconds=");
          Serial.println(wateringSeconds);
          forceValveImmediate(true, "schedule_on");
          updateLastValveAction("schedule_on", "schedule start");
          lastScheduleStartKeyA = scheduleKey;
          pushEvent("schedule_start", String("A區排程澆水啟用，最大澆水 ") + String(wateringSeconds) + " 秒，出水偵測逾時 " + String(noWaterTimeoutSeconds) + " 秒。");
          if (notifyStartWater) sendNtfy("🚿 A 區排程澆水啟用", "A區排程已啟動。", "droplet");
          statusDirty = true;
          return;
        }
      }
    }
  }
}

